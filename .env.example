# webdav = Synology WebDAV access with password entered in the app
# local = read from a folder mounted on the machine running the backend
STORAGE_MODE=webdav

# Backend
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Synology WebDAV mode
# Example shape: https://your-nas.local:5006/path/to/image-folder/
SYNOLOGY_WEBDAV_URL=https://your-synology-host:5006/path/to/image-folder/
SYNOLOGY_USERNAME=your-synology-user

# Local mode alternative
# LOCAL_IMAGE_FOLDER=/Volumes/your-mounted-synology-folder
